<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-800 text-white p-10">
        <div class="flex justify-end">
            <a href="/logout" class="bg-red-400 px-3 py-2 rounded-md inline-block ">Logout</a>
        </div>
        
        <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-md overflow-hidden">
                <img class="w-full h-full object-cover" src="/images/uploads/<%= user.profilepic %>" alt="" >
            </div>
            <h2 class="text-2xl mb-3">Hello, <%= user.name%></h2>
        </div>


        <h5 class="mb-4 mt-3">You can create a new post.</h5>
        <form action="/post" method="post">
            <textarea class="w-1/3 p-2 outline-none block resize-none bg-transparent text-white border-2 border-zinc-600 rounded-md" placeholder="What's on your mind ?" name="content"></textarea>
            <input class="bg-blue-600 p-2 rounded-md block mt-2 cursor-pointer" type="submit" value="Create Post">
        </form>
        
        <div class="posts mt-10">
            <h3 class="text-zinc-400">Your Posts</h3>
            <div class="postcontainer mt-5">
                <% user.posts.reverse().forEach(function(post){ %>
                <div class="post w-1/3 p-4 mb-3 border-[1px] border-zinc-600 rounded-md">
                    <h4 class="text-blue-400 mb-2">@<%= user.name%></h4>
                    <p text-sm tracking-tight><%= post.content %> </p>
                    <small><%= post.likes.length%> likes</small>
                    <div class="btns flex gap-4 mt-1">
                        <a class="text-pink-400" href="/like/<%= post._id%>">
                            
                            <%= post.likes.indexOf(user._id) === -1 ? "Like" : "Unlike" %>
                        </a>
                        <a class="text-zinc-400" href="/edit/<%= post._id %>">edit</a>
                    </div>
                </div>
                <%}) %>
            </div>

            
        </div>

        
    </div>
</body>
</html>