<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-800 text-white p-10">
        <div class="flex justify-end">
            <a href="/logout" class="bg-red-400 px-3 py-2 rounded-md inline-block ">Logout</a>
        </div>
        <h5 class="mb-4 ">Edit Post</h5>
        <form action="/update/<%= post._id%>" method="post">
            <textarea class="w-1/3 p-2 outline-none block resize-none bg-transparent text-white border-2 border-zinc-600 rounded-md" placeholder="What's on your mind ?" name="content"> <%= post.content%> </textarea>
            <input class="bg-yellow-600 text-black p-2 rounded-md block mt-2 cursor-pointer" type="submit" value="Update Post">
        </form>
        

        
    </div>
</body>
</html>