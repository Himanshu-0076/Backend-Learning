<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 ">
        <div class="form p-10">
            <form action="/create" method="post">
                <input class="w-full text-white rounded-md outline-none block px-5 py-5 bg-zinc-500" type="text" placeholder="Title goes here..." name="title">
                <textarea class="w-full text-white rounded-md outline-none block px-5 py-5 mt-2 bg-zinc-500 resize-none" placeholder="write your task details" name="details"></textarea>
                <input class="mt-2 p-2 bg-blue-600 rounded-md text-white hover:bg-blue-400" type="submit" value="Create Task">
            </form>
        </div>
        
        <div class="tasks p-10 flex gap-4 flex-wrap">
            
        <% if(files.length > 0) { %> 
            <% files.forEach(function(val){ %>
            <div class="task w-72 px-3 py-4 rounded-md bg-zinc-800">
                    <div class="flex justify-between items-center w-full ">
                    <h1 class="text-white text-3xl tracking-tighter" ><%= val%></h1>
                    <a class="text-zinc-500 hover:text-zinc-600 cursor-pointer" href="/edit/<%= val%>">Edit</a>
                    </div>
                
                <a class="inline-block mt-3 text-blue-500" href="/file/<%= val%>"> Read more.</a>
            </div>
            <% }) %>
            <% } else { %> 
                <h3 class="text-white ">No Tasks Yet.</h3>
                <% }
             %>
            
        </div>
    </div>

    <script src="/javascripts/script.js"></script>
</body>
</html>