<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit File</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10">
        <h1 class="text-white text-3xl tracking-tighter">Editing: <%= filename %></h1>
    
    <!-- Form submits to the update route with the current filename -->
    <form action="/update/<%= filename%>" method="POST">
        <textarea name="newdetails" class="w-full text-white rounded-md outline-none block px-5 py-5 mt-2 bg-zinc-500 " placeholder="write your task details" rows="10" cols="50"><%= filedata %></textarea>
        <div >
            <button class="inline-block mt-8 text-white-500 bg-blue-500 rounded-md p-2" type="submit">Save Changes</button>
            <a class="inline-block mt-8 text-white-500 bg-red-500 p-2 rounded-md" href="/">Cancel</a>
        </div>
    </form>
    </div>
</body>
</html>