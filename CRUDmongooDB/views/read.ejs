<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full h-full bg-zinc-800 p-10 text-white">
        <a href="/" class="text-blue-500 " >Go to Back</a>
        <h1 class="text-3xl tracking-tighter mb-3 mt-4">All User</h1>
        <div class="users flex gap-4 flex-wrap">

            <% if(users.length>0){%> 
                
                 <% users.forEach(function(user){ %>
              <div class="user w-72 p-4 bg-zinc-600 rounded-lg">
                 <div class="w-full bg-zinc-500 h-52 rounded-lg overflow-hidden">
                    <img class="w-full h-full object-cover" src="<%= user.image%>">
                 </div>
                 <h3 class="text-2xl mt-2 tracking-tighter"><%= user.name%></h3>
                 <h5 class="text-zinc-300"><%= user.email%></h5>
                 <div class="flex gap-6 mt-10">
                    <a class="text-zinc-300 hover:text-zinc-400" href="/edit/<%= user._id%>">Edit</a>
                    <a class="text-red-400 hover:text-red-500" href="/delete/<%= user._id%>">Delete </a>
                 </div>
             </div>
            <%})%>

                <%}else {%> 
                    <h1 class="text-3xl">No user Yet......</h1>
                    <%}  %>






           
        </div>
    </div>
</body>
</html>